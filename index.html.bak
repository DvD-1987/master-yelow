<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>вҡ?й»„иҖҒеёҲзҡ„еҚ°е°јз…ӨзӮӯиҙёжҳ“д№Ӣж—?вҡ?/title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            /* иөӣеҚҡжңӢе…Ӣи’ёжұҪйЈҺй…Қиү?*/
            --steam-bronze: #8B4513;
            --steam-copper: #B87333;
            --steam-gold: #D4AF37;
            --steam-rust: #A0522D;
            --neon-blue: #00FFFF;
            --neon-orange: #FF6600;
            --neon-pink: #FF0080;
            --dark-metal: #1a1a2e;
            --darker-metal: #0f0f1a;
            --panel-bg: #16213e;
            --grid-line: rgba(0, 255, 255, 0.1);
        }

        body {
            font-family: 'Noto Sans SC', sans-serif;
            background: var(--darker-metal);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            color: #fff;
            position: relative;
            overflow-x: hidden;
        }

        /* и’ёжұҪзҪ‘ж јиғҢжҷҜ */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(90deg, var(--grid-line) 1px, transparent 1px),
                linear-gradient(var(--grid-line) 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
            z-index: 0;
        }

        /* и’ёжұҪз®ЎйҒ“иЈ…йҘ° */
        body::after {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(ellipse at 20% 80%, rgba(184, 115, 51, 0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(0, 255, 255, 0.1) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(212, 175, 55, 0.05) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        .game-container {
            width: 100%;
            max-width: 1000px;
            background: linear-gradient(145deg, var(--panel-bg) 0%, var(--dark-metal) 100%);
            border: 3px solid var(--steam-copper);
            border-radius: 12px;
            box-shadow: 
                0 0 0 2px var(--steam-bronze),
                0 0 30px rgba(0, 255, 255, 0.3),
                inset 0 0 60px rgba(0, 0, 0, 0.5);
            position: relative;
            z-index: 1;
            overflow: hidden;
        }

        /* й“Ҷй’үиЈ…йҘ° */
        .game-container::before {
            content: '';
            position: absolute;
            top: 10px;
            left: 10px;
            right: 10px;
            bottom: 10px;
            border: 1px dashed var(--steam-copper);
            border-radius: 8px;
            pointer-events: none;
            z-index: 2;
        }

        /* еӨҙйғЁ - и’ёжұҪд»ӘиЎЁзӣҳйЈҺж ?*/
        .header {
            background: linear-gradient(180deg, var(--steam-bronze) 0%, var(--steam-rust) 100%);
            border-bottom: 4px solid var(--steam-gold);
            padding: 25px 20px;
            text-align: center;
            position: relative;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
        }

        .header::before,
        .header::after {
            content: 'в—?;
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            color: var(--steam-gold);
            font-size: 1.5rem;
        }

        .header::before { left: 30px; }
        .header::after { right: 30px; }

        .header h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            color: var(--neon-blue);
            text-shadow: 
                0 0 10px var(--neon-blue),
                0 0 20px var(--neon-blue),
                2px 2px 4px rgba(0, 0, 0, 0.8);
            margin-bottom: 8px;
            letter-spacing: 3px;
        }

        .header p {
            font-size: 1rem;
            color: var(--steam-gold);
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8);
        }

        /* еҜјиҲӘж ?*/
        .nav-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(90deg, var(--dark-metal) 0%, var(--panel-bg) 50%, var(--dark-metal) 100%);
            border-bottom: 2px solid var(--steam-copper);
            padding: 12px 20px;
            position: relative;
        }

        .nav-bar::before {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--neon-blue), transparent);
        }

        .nav-btn {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.85rem;
            padding: 10px 20px;
            background: linear-gradient(145deg, var(--steam-bronze) 0%, var(--steam-rust) 100%);
            color: var(--neon-blue);
            border: 2px solid var(--steam-copper);
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 
                0 4px 0 var(--steam-bronze),
                0 0 10px rgba(0, 255, 255, 0.3);
        }

        .nav-btn:hover {
            background: linear-gradient(145deg, var(--steam-copper) 0%, var(--steam-gold) 100%);
            color: var(--dark-metal);
            box-shadow: 
                0 0 20px var(--neon-blue),
                0 4px 0 var(--steam-bronze);
            transform: translateY(-2px);
        }

        .nav-btn:active {
            transform: translateY(2px);
            box-shadow: 
                0 0 10px var(--neon-blue),
                0 2px 0 var(--steam-bronze);
        }

        /* еұһжҖ§ж Ҹ - и’ёжұҪд»ӘиЎЁзӣ?*/
        .stats-bar {
            display: flex;
            justify-content: space-around;
            background: linear-gradient(180deg, var(--dark-metal) 0%, var(--panel-bg) 100%);
            border-bottom: 2px solid var(--steam-copper);
            padding: 20px 15px;
            position: relative;
        }

        .stat-item {
            text-align: center;
            padding: 15px 20px;
            background: linear-gradient(145deg, #2a2a4a 0%, #1a1a2e 100%);
            border: 2px solid var(--steam-copper);
            border-radius: 8px;
            min-width: 140px;
            position: relative;
            box-shadow: 
                inset 0 0 20px rgba(0, 0, 0, 0.5),
                0 0 10px rgba(0, 255, 255, 0.1);
        }

        .stat-item::before {
            content: '';
            position: absolute;
            top: 5px;
            left: 5px;
            right: 5px;
            bottom: 5px;
            border: 1px solid rgba(0, 255, 255, 0.2);
            border-radius: 4px;
            pointer-events: none;
        }

        .stat-label {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.75rem;
            color: var(--steam-gold);
            margin-bottom: 8px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stat-value {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            display: block;
            text-shadow: 0 0 10px currentColor;
        }

        .stat-value.high { color: var(--neon-pink); }
        .stat-value.medium { color: var(--neon-orange); }
        .stat-value.low { color: var(--neon-blue); }

        /* жёёжҲҸеҶ…е®№еҢ?*/
        .game-content {
            padding: 30px;
            min-height: 450px;
            position: relative;
        }

        /* и’ёжұҪжңӢе…ӢжҢүй’® */
        .btn {
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            padding: 15px 35px;
            border: 2px solid;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 2px;
            position: relative;
            overflow: hidden;
            margin: 10px;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }

        .btn:hover::before {
            left: 100%;
        }

        .btn-primary {
            background: linear-gradient(145deg, var(--steam-bronze) 0%, var(--steam-rust) 100%);
            color: var(--neon-blue);
            border-color: var(--steam-copper);
            box-shadow: 
                0 6px 0 var(--steam-bronze),
                0 0 20px rgba(0, 255, 255, 0.3);
        }

        .btn-primary:hover {
            background: linear-gradient(145deg, var(--steam-copper) 0%, var(--steam-gold) 100%);
            color: var(--dark-metal);
            box-shadow: 
                0 0 30px var(--neon-blue),
                0 6px 0 var(--steam-bronze);
            transform: translateY(-3px);
        }

        .btn-secondary {
            background: linear-gradient(145deg, #2a2a4a 0%, #1a1a2e 100%);
            color: var(--steam-gold);
            border-color: var(--steam-copper);
            box-shadow: 
                0 6px 0 #1a1a2e,
                0 0 15px rgba(212, 175, 55, 0.2);
        }

        .btn-secondary:hover {
            background: linear-gradient(145deg, #3a3a5a 0%, #2a2a4a 100%);
            box-shadow: 
                0 0 25px var(--steam-gold),
                0 6px 0 #1a1a2e;
            transform: translateY(-3px);
        }

        .btn-danger {
            background: linear-gradient(145deg, #8B0000 0%, #5C0000 100%);
            color: #fff;
            border-color: #FF4444;
            box-shadow: 
                0 6px 0 #5C0000,
                0 0 20px rgba(255, 0, 0, 0.3);
        }

        .btn-danger:hover {
            background: linear-gradient(145deg, #AA0000 0%, #8B0000 100%);
            box-shadow: 
                0 0 30px #FF4444,
                0 6px 0 #5C0000;
            transform: translateY(-3px);
        }

        .btn:active {
            transform: translateY(3px);
            box-shadow: 
                0 0 15px currentColor,
                0 3px 0 var(--steam-bronze);
        }

        /* еҶ…е®№жЎ?- и’ёжұҪйқўжқҝ */
        .content-box {
            background: linear-gradient(145deg, rgba(42, 42, 74, 0.8) 0%, rgba(22, 33, 62, 0.9) 100%);
            border: 2px solid var(--steam-copper);
            border-radius: 10px;
            padding: 25px;
            margin: 20px 0;
            box-shadow: 
                0 0 20px rgba(0, 255, 255, 0.1),
                inset 0 0 30px rgba(0, 0, 0, 0.3);
            position: relative;
        }

        .content-box::before {
            content: '';
            position: absolute;
            top: 8px;
            left: 8px;
            right: 8px;
            bottom: 8px;
            border: 1px dashed rgba(0, 255, 255, 0.3);
            border-radius: 6px;
            pointer-events: none;
        }

        .content-box h3 {
            font-family: 'Orbitron', sans-serif;
            color: var(--neon-blue);
            font-size: 1.3rem;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--steam-copper);
            text-shadow: 0 0 10px var(--neon-blue);
        }

        .content-box p, .content-box li {
            font-size: 1.05rem;
            color: #e0e0e0;
            line-height: 1.9;
            margin-bottom: 12px;
        }

        .content-box ul {
            list-style: none;
            padding-left: 0;
        }

        .content-box li {
            padding-left: 25px;
            position: relative;
        }

        .content-box li::before {
            content: 'в–?;
            position: absolute;
            left: 0;
            color: var(--neon-orange);
            text-shadow: 0 0 10px var(--neon-orange);
        }

        .content-box .highlight {
            color: var(--neon-blue);
            text-shadow: 0 0 10px var(--neon-blue);
            font-weight: 600;
        }

        .content-box .danger-text {
            color: var(--neon-pink);
            text-shadow: 0 0 10px var(--neon-pink);
        }

        /* еү§жғ…еұ•зӨә */
        .story-display {
            background: linear-gradient(145deg, rgba(42, 42, 74, 0.9) 0%, rgba(22, 33, 62, 0.95) 100%);
            border: 2px solid var(--steam-copper);
            border-radius: 10px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: 
                0 0 25px rgba(0, 255, 255, 0.15),
                inset 0 0 40px rgba(0, 0, 0, 0.4);
            position: relative;
        }

        .story-display::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--neon-blue), transparent);
        }

        .story-display h3 {
            font-family: 'Orbitron', sans-serif;
            color: var(--neon-orange);
            font-size: 1.4rem;
            margin-bottom: 15px;
            text-shadow: 0 0 15px var(--neon-orange);
        }

        .story-display p {
            color: #e8e8e8;
            font-size: 1.1rem;
            line-height: 2;
            margin-bottom: 15px;
        }

        .story-display strong {
            color: var(--neon-blue);
            text-shadow: 0 0 8px var(--neon-blue);
        }

        /* е…іеҚЎеҫҪз«  */
        .level-badge {
            display: inline-block;
            background: linear-gradient(145deg, var(--steam-bronze) 0%, var(--steam-rust) 100%);
            color: var(--neon-blue);
            padding: 12px 25px;
            border: 2px solid var(--steam-gold);
            border-radius: 6px;
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            margin-bottom: 15px;
            text-shadow: 0 0 10px var(--neon-blue);
            box-shadow: 
                0 0 20px rgba(0, 255, 255, 0.2),
                inset 0 0 10px rgba(0, 0, 0, 0.3);
        }

        .level-badge.elite {
            background: linear-gradient(145deg, #4a0080 0%, #2a0050 100%);
            border-color: var(--neon-pink);
            color: var(--neon-pink);
            text-shadow: 0 0 15px var(--neon-pink);
            animation: pulse-pink 2s infinite;
        }

        @keyframes pulse-pink {
            0%, 100% { box-shadow: 0 0 20px rgba(255, 0, 128, 0.4); }
            50% { box-shadow: 0 0 40px rgba(255, 0, 128, 0.8); }
        }

        /* й—®йўҳеҢәеҹҹ */
        .question-area {
            background: linear-gradient(145deg, rgba(42, 42, 74, 0.8) 0%, rgba(22, 33, 62, 0.9) 100%);
            border: 2px solid var(--steam-copper);
            border-radius: 10px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: 0 0 20px rgba(0, 255, 255, 0.1);
        }

        .question-counter {
            font-family: 'Orbitron', sans-serif;
            color: var(--steam-gold);
            font-size: 0.95rem;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .question-text {
            font-size: 1.2rem;
            color: #fff;
            margin-bottom: 25px;
            line-height: 1.8;
            font-weight: 500;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
        }

        /* йҖүйЎ№жҢүй’® */
        .options-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .option-btn {
            font-family: 'Noto Sans SC', sans-serif;
            font-size: 1rem;
            padding: 18px 20px;
            background: linear-gradient(145deg, rgba(42, 42, 74, 0.9) 0%, rgba(22, 33, 62, 0.95) 100%);
            border: 2px solid var(--steam-copper);
            border-radius: 8px;
            color: #e0e0e0;
            text-align: left;
            cursor: pointer;
            transition: all 0.3s ease;
            line-height: 1.6;
            position: relative;
            overflow: hidden;
        }

        .option-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.1), transparent);
            transition: left 0.5s;
        }

        .option-btn:hover:not(:disabled)::before {
            left: 100%;
        }

        .option-btn:hover:not(:disabled) {
            border-color: var(--neon-blue);
            color: var(--neon-blue);
            box-shadow: 
                0 0 20px rgba(0, 255, 255, 0.3),
                inset 0 0 20px rgba(0, 255, 255, 0.05);
            transform: translateX(5px);
        }

        .option-btn:disabled {
            cursor: not-allowed;
            opacity: 0.7;
        }

        .option-btn.correct {
            background: linear-gradient(145deg, rgba(0, 100, 0, 0.8) 0%, rgba(0, 60, 0, 0.9) 100%);
            border-color: #00FF00;
            color: #00FF00;
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.4);
        }

        .option-btn.wrong {
            background: linear-gradient(145deg, rgba(100, 0, 0, 0.8) 0%, rgba(60, 0, 0, 0.9) 100%);
            border-color: #FF4444;
            color: #FF8888;
            box-shadow: 0 0 20px rgba(255, 0, 0, 0.4);
        }

        .option-btn.show-correct {
            background: linear-gradient(145deg, rgba(0, 100, 0, 0.9) 0%, rgba(0, 60, 0, 1) 100%);
            border-color: #00FF00;
            border-width: 3px;
            color: #00FF00;
            box-shadow: 0 0 30px rgba(0, 255, 0, 0.6);
            animation: pulse-green 1s infinite;
        }

        @keyframes pulse-green {
            0%, 100% { box-shadow: 0 0 20px rgba(0, 255, 0, 0.6); }
            50% { box-shadow: 0 0 40px rgba(0, 255, 0, 1); }
        }

        .option-letter {
            display: inline-block;
            width: 32px;
            height: 32px;
            background: linear-gradient(145deg, var(--steam-bronze) 0%, var(--steam-rust) 100%);
            color: var(--neon-blue);
            text-align: center;
            line-height: 32px;
            margin-right: 12px;
            border-radius: 50%;
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            text-shadow: 0 0 10px var(--neon-blue);
            box-shadow: 0 0 10px rgba(0, 255, 255, 0.2);
        }

        .option-btn.correct .option-letter,
        .option-btn.show-correct .option-letter {
            background: linear-gradient(145deg, #00AA00 0%, #008800 100%);
            color: #fff;
            text-shadow: 0 0 10px #fff;
        }

        .option-btn.wrong .option-letter {
            background: linear-gradient(145deg, #AA0000 0%, #880000 100%);
            color: #fff;
        }

        /* еҸҚйҰҲеҢәеҹҹ */
        .feedback-box {
            margin-top: 20px;
            padding: 20px;
            border: 2px solid;
            border-radius: 8px;
            display: none;
            position: relative;
            overflow: hidden;
        }

        .feedback-box.show {
            display: block;
            animation: slideIn 0.4s ease;
        }

        @keyframes slideIn {
            0% { opacity: 0; transform: translateY(-20px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        .feedback-box.correct {
            background: linear-gradient(145deg, rgba(0, 80, 0, 0.9) 0%, rgba(0, 40, 0, 0.95) 100%);
            border-color: #00FF00;
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.3);
        }

        .feedback-box.wrong {
            background: linear-gradient(145deg, rgba(80, 0, 0, 0.9) 0%, rgba(40, 0, 0, 0.95) 100%);
            border-color: #FF4444;
            box-shadow: 0 0 20px rgba(255, 0, 0, 0.3);
        }

        .feedback-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.2rem;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .feedback-box.correct .feedback-title {
            color: #00FF00;
            text-shadow: 0 0 15px #00FF00;
        }

        .feedback-box.wrong .feedback-title {
            color: #FF6666;
            text-shadow: 0 0 15px #FF4444;
        }

        .feedback-explanation {
            color: #e0e0e0;
            font-size: 1rem;
            line-height: 1.8;
            margin-bottom: 15px;
        }

        .effect-changes {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .effect-item {
            padding: 8px 15px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.9rem;
            font-family: 'Orbitron', sans-serif;
        }

        .effect-positive {
            background: rgba(0, 100, 0, 0.8);
            color: #00FF00;
            border: 1px solid #00FF00;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
        }

        .effect-negative {
            background: rgba(100, 0, 0, 0.8);
            color: #FF8888;
            border: 1px solid #FF4444;
            box-shadow: 0 0 10px rgba(255, 0, 0, 0.3);
        }

        /* иҝӣеәҰжқ?- и’ёжұҪеҺӢеҠӣиЎЁйЈҺж ?*/
        .progress-container {
            background: linear-gradient(180deg, var(--dark-metal) 0%, var(--panel-bg) 100%);
            border-top: 2px solid var(--steam-copper);
            padding: 20px 30px;
            position: relative;
        }

        .progress-container::before {
            content: '';
            position: absolute;
            top: -2px;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--neon-orange), transparent);
        }

        .progress-bar {
            height: 28px;
            background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%);
            border: 2px solid var(--steam-copper);
            border-radius: 14px;
            overflow: hidden;
            position: relative;
            box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.5);
        }

        .progress-bar::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: repeating-linear-gradient(
                90deg,
                transparent,
                transparent 10px,
                rgba(0, 0, 0, 0.3) 10px,
                rgba(0, 0, 0, 0.3) 12px
            );
            z-index: 2;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--steam-bronze) 0%, var(--neon-orange) 50%, var(--steam-gold) 100%);
            transition: width 0.5s ease;
            position: relative;
            box-shadow: 0 0 20px var(--neon-orange);
        }

        .progress-fill::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(180deg, rgba(255,255,255,0.3) 0%, transparent 50%, rgba(0,0,0,0.3) 100%);
        }

        .progress-text {
            text-align: center;
            margin-top: 12px;
            color: var(--neon-blue);
            font-family: 'Orbitron', sans-serif;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 10px var(--neon-blue);
        }

        /* ејҖе§Ӣз•Ңйқ?*/
        .start-screen {
            text-align: center;
            padding: 40px 20px;
        }

        .start-screen h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2rem;
            color: var(--neon-blue);
            margin-bottom: 20px;
            text-shadow: 0 0 20px var(--neon-blue);
        }

        .start-screen p {
            font-size: 1.1rem;
            color: #e0e0e0;
            margin-bottom: 30px;
            line-height: 2;
        }

        /* е…іеҚЎйҖүжӢ© */
        .level-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }

        .level-card {
            background: linear-gradient(145deg, rgba(42, 42, 74, 0.9) 0%, rgba(22, 33, 62, 0.95) 100%);
            border: 2px solid var(--steam-copper);
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .level-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.1), transparent);
            transition: left 0.5s;
        }

        .level-card:hover::before {
            left: 100%;
        }

        .level-card:hover {
            border-color: var(--neon-blue);
            box-shadow: 0 0 25px rgba(0, 255, 255, 0.3);
            transform: translateY(-5px);
        }

        .level-card.locked {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .level-card.completed {
            border-color: #00FF00;
            background: linear-gradient(145deg, rgba(0, 60, 0, 0.9) 0%, rgba(0, 30, 0, 0.95) 100%);
        }

        .level-number {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--neon-blue);
            margin-bottom: 8px;
            text-shadow: 0 0 15px var(--neon-blue);
        }

        .level-name {
            font-size: 1rem;
            color: var(--steam-gold);
        }

        /* з»“жһңз•Ңйқў */
        .result-screen {
            text-align: center;
            padding: 40px 20px;
        }

        .result-screen h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.2rem;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 3px;
        }

        .result-screen.success h2 {
            color: #00FF00;
            text-shadow: 0 0 30px #00FF00;
        }

        .result-screen.fail h2 {
            color: #FF4444;
            text-shadow: 0 0 30px #FF4444;
        }

        .result-stats {
            display: flex;
            justify-content: center;
            gap: 25px;
            margin: 30px 0;
            flex-wrap: wrap;
        }

        .result-stat {
            padding: 20px 30px;
            background: linear-gradient(145deg, rgba(42, 42, 74, 0.9) 0%, rgba(22, 33, 62, 0.95) 100%);
            border: 2px solid var(--steam-copper);
            border-radius: 10px;
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.1);
        }

        .result-stat-label {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.85rem;
            color: var(--steam-gold);
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .result-stat-value {
            font-family: 'Orbitron', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            text-shadow: 0 0 15px currentColor;
        }

        /* йҡҗи—Ҹ */
        .hidden {
            display: none !important;
        }

        /* жҢүй’®з»?*/
        .button-group {
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
            margin-top: 25px;
        }

        /* е“Қеә”еј?*/
        @media (max-width: 768px) {
            .header h1 {
                font-size: 1.3rem;
                letter-spacing: 2px;
            }

            .header::before,
            .header::after {
                display: none;
            }

            .stats-bar {
                flex-wrap: wrap;
                gap: 10px;
            }

            .stat-item {
                min-width: 100px;
                padding: 12px 15px;
            }

            .question-text {
                font-size: 1.05rem;
            }

            .option-btn {
                font-size: 0.95rem;
                padding: 15px;
            }

            .btn {
                font-size: 0.9rem;
                padding: 12px 25px;
            }

            .level-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="game-container">
        <!-- еӨҙйғЁ -->
        <div class="header">
            <h1>вҡ?й»„иҖҒеёҲзҡ„еҚ°е°јз…ӨзӮӯиҙёжҳ“д№Ӣж—?вҡ?/h1>
            <p>STEAMPUNK TRADING ADVENTURE</p>
        </div>

        <!-- еҜјиҲӘж ?-->
        <div class="nav-bar">
            <button class="nav-btn" onclick="game.goHome()">в—Җ иҝ”еӣһдё»йЎө</button>
            <div>
                <button class="nav-btn" onclick="game.restart()">вҶ?йҮҚж–°ејҖе§?/button>
            </div>
        </div>

        <!-- еұһжҖ§ж Ҹ -->
        <div class="stats-bar" id="statsBar">
            <div class="stat-item">
                <span class="stat-label">дё“дёҡзҹҘиҜҶ</span>
                <span class="stat-value" id="knowledgeValue">50</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">иҖҒжқҝдҝЎд»»еә?/span>
                <span class="stat-value" id="trustValue">50</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">йЈҺйҷ©еҖ?/span>
                <span class="stat-value high" id="riskValue">20</span>
            </div>
        </div>

        <!-- жёёжҲҸеҶ…е®№еҢ?-->
        <div class="game-content" id="gameContent">
            <!-- еҠЁжҖҒеҶ…е®№е°ҶеңЁиҝҷйҮҢжҳҫзӨ?-->
        </div>

        <!-- иҝӣеәҰжқ?-->
        <div class="progress-container" id="progressContainer">
            <div class="progress-bar">
                <div class="progress-fill" id="progressFill" style="width: 0%"></div>
            </div>
            <div class="progress-text" id="progressText">з¬?1 е…?/ е…?10 е…?/div>
        </div>
    </div>

    <script src="questions.js"></script>
    <script src="questions_level7.js"></script>
    <script src="questions_level8.js"></script>
    <script src="questions_level9.js"></script>
    <script src="questions_level10.js"></script>
    <script src="game.js"></script>
    <script>
        // еҲқе§ӢеҢ–жёёжҲ?        document.addEventListener('DOMContentLoaded', function() {
            game.init();
        });
    </script>
</body>
</html>
